# Copy to .env and fill in.

# Anthropic API key. The only network calls this app makes are to Anthropic
# and (if configured below) Datadog.
ANTHROPIC_API_KEY=sk-ant-...

# Anthropic API base URL. Override to point at a proxy or compatible endpoint.
ANTHROPIC_BASE_URL=https://api.anthropic.com

# OPTIONAL. Colon-separated directories that runs may target — an allowlist.
# When set, a run's repo_path must resolve inside one of these. When unset
# (the default), any existing directory may be chosen via the file browser in
# the UI. File/shell tools are always jailed to the chosen repo either way.
# PROJECT_ROOTS=/Users/you/Dev

# Datadog metrics integration (see DATADOG.md). Leave DATADOG_API_KEY unset
# to disable — no Datadog calls are made without it.
# DATADOG_API_KEY=
# DATADOG_SITE=datadoghq.com
# DATADOG_METRIC_PREFIX=agent_studio
# DATADOG_TAGS=env:dev
# DATADOG_SSL_VERIFY=false

# GitHub token for the github_create_pr tool (needs `pull_request:write` on
# the target repo, e.g. a fine-grained PAT). Leave unset to disable PR
# creation — the tool then returns a clear error instead of a silent no-op.
# GITHUB_TOKEN=

# Optional overrides
# DATA_DIR=data
# PORT=8000
